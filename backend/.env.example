# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Aiven PostgreSQL)
# Render/Postgres-friendly alternative:
# DATABASE_URL=postgres://user:password@host:5432/database
DATABASE_URL=

# Preferred single-string form:
# DATABASE_URL=postgres://avnadmin:password@your-aiven-host.aivencloud.com:12345/defaultdb?sslmode=require
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your_secure_password
DB_NAME=defaultdb
# Optional: Aiven CA certificate for production SSL verification
# Download from Aiven console → Service → Overview → CA Certificate
DB_SSL_CA=
# Optional: local path to the Aiven CA file instead of pasting the certificate
DB_SSL_CA_PATH=
# Optional: set to true when you want strict CA verification
DB_SSL_REJECT_UNAUTHORIZED=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production

# Public Base URL (required for webhooks)
PUBLIC_BASE_URL=https://your-domain.com
FRONTEND_BASE_URL=https://your-frontend-domain.com
APP_URL=https://your-frontend-domain.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://frontend-anandh0us-projects.vercel.app

# Optional: Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# Optional: GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://your-domain.com/auth/github/callback

# Optional: AI Services
OPENAI_API_KEY=your_openai_api_key
SARVAM_API_KEY=your_sarvam_api_key

# Optional: Mailgun Email
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=your_mailgun_domain
MAILGUN_FROM=Versafic <postmaster@your_mailgun_domain>
MAILGUN_BASE_URL=https://api.mailgun.net

# Razorpay Configuration (Test Mode)
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Optional: Twilio (for phone call handling)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
TWILIO_ACCOUNT_MODE=trial
TWILIO_AUTO_SYNC_WEBHOOKS=true
CALL_DEMO_MODE=true

# Optional: Exotel (for multi-business AI calling)
# Mumbai accounts typically use https://api.in.exotel.com
EXOTEL_SID=your_exotel_sid
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_NUMBER=your_exotel_virtual_number
EXOTEL_API_BASE_URL=https://api.in.exotel.com
# Optional override if your Exotel account requires a pre-created applet/flow URL
EXOTEL_CALL_FLOW_URL=
# Optional shared secret for POST /call/start
EXOTEL_INTERNAL_API_KEY=
# Optional outbound call limits
EXOTEL_TIME_LIMIT_SECONDS=180
EXOTEL_TIMEOUT_SECONDS=30
EXOTEL_DEFAULT_MESSAGE=Hello. We could not identify the correct business for this call right now.
