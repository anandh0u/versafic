# API Configuration
# Backend API URL - update this to your deployed backend URL
VITE_API_URL=http://localhost:5000

# Billing mode:
# - live: expect backend billing endpoints to fully drive the experience
# - hybrid: use live auth/wallet/payment where available + local demo/autopay simulation
# - mock: run the full billing story locally without backend billing data
VITE_BILLING_MODE=hybrid

# Optional: Google OAuth Client ID (for Google Sign-In)
VITE_GOOGLE_CLIENT_ID=your_google_client_id
